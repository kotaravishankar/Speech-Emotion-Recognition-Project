_type":"code","source":"# ══════════════════════════════════════════════════════════════════════════════\n#  MODEL 3 — CNN-BiLSTM Hybrid  (best of both: local + temporal patterns)\n#\n#  Architecture:\n#  CNN blocks extract local spectral patterns from MFCC frames\n#  → BiLSTM layers capture how those patterns evolve over time\n#  → Scalar branch adds cleaned hand-crafted features\n#  → Dense head with progressive dropout\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef build_cnn_bilstm(seq_shape, sca_shape, num_classes=NUM_CLASSES):\n    seq_in = Input(shape=seq_shape, name='seq_input')\n\n    # CNN feature extractor\n    x = Conv1D(64, 5, padding='same', activation='relu',\n               kernel_regularizer=l2(1e-4))(seq_in)\n    x = BatchNormalization()(x)\n    x = MaxPooling1D(2)(x)\n    x = Dropout(0.2)(x)\n\n    x = Conv1D(128, 3, padding='same', activation='relu',\n               kernel_regularizer=l2(1e-4))(x)\n    x = BatchNormalization()(x)\n    x = MaxPooling1D(2)(x)\n    x = Dropout(0.2)(x)\n\n    # Residual block\n    skip = Conv1D(256, 1, padding='same')(x)\n    x = Conv1D(256, 3, padding='same', activation='relu',\n               kernel_regularizer=l2(1e-4))(x)\n    x = BatchNormalization()(x)\n    x = Conv1D(256, 3, padding='same', kernel_regularizer=l2(1e-4))(x)\n    x = BatchNormalization()(x)\n    x = Add()([x, skip])\n    x = tf.keras.activations.relu(x)\n    x = Dropout(0.25)(x)\n\n    # BiLSTM temporal modelling (NO recurrent_dropout for GPU speed)\n    x = Bidirectional(LSTM(128, return_sequences=True,\n                           kernel_regularizer=l2(1e-4)))(x)\n    x = BatchNormalization()(x)\n    x = Dropout(0.3)(x)\n\n    x = Bidirectional(LSTM(64, kernel_regularizer=l2(1e-4)))(x)\n    x = BatchNormalization()(x)\n    x = Dropout(0.25)(x)\n\n    sca_in = Input(shape=sca_shape, name='sca_input')\n    s = Dense(32, activation='relu')(sca_in)\n    s = BatchNormalization()(s)\n\n    merged = tf.keras.layers.concatenate([x, s])\n    merged = Dense(256, activation='relu', kernel_regularizer=l2(1e-4))(merged)\n    merged = Dropout(0.3)(merged)\n    merged = Dense(128, activation='relu', kernel_regularizer=l2(1e-4))(merged)\n    merged = Dropout(0.2)(merged)\n    out    = Dense(num_classes, activation='softmax')(merged)\n\n    model = Model(inputs=[seq_in, sca_in], outputs=out, name='CNN_BiLSTM')\n    model.compile(\n        optimizer=tf.keras.optimizers.Adam(learning_rate=5e-4),\n        loss='categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    return model\n\ncnn_lstm_model = build_cnn_bilstm(X_seq_tr.shape[1:], X_sca_tr.shape[1:])\ncnn_lstm_model.summary()\nprint(\"✅ CNN-BiLSTM built.\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:22:25.314031Z","iopub.execute_input":"2026-02-28T20:22:25.314264Z","iopub.status.idle":"2026-02-28T20:22:25.545879Z","shell.execute_reply.started":"2026-02-28T20:22:25.314243Z","shell.execute_reply":"2026-02-28T20:22:25.545320Z"},"papermill":{"duration":0.414919,"end_time":"2026-02-28T00:06:02.377778","exception":false,"start_time":"2026-02-28T00:06:01.962859","status":"completed"},"tags":[],"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"CNN_BiLSTM\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"CNN_BiLSTM\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mConnected to     \u001b[0m\u001b[1m \u001b[0m┃\n┡━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━╇