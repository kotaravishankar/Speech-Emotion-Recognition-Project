_files, N_FRAMES, N_MFCC)\nall_scalars   = []   # shape: (n_files, 7)  — cascading-cleaned scalar features\nall_labels    = []\n\nfor idx, (_, row) in enumerate(metadata_final.iterrows()):\n    if idx % 500 == 0:\n        print(f\"  Processing file {idx}/{len(metadata_final)} ...\")\n    try:\n        y, sr = librosa.load(row[\"file\"], sr=22050)   # resample to consistent sr\n        stft  = np.abs(librosa.stft(y))\n\n        # ── SEQUENCE: 40-coeff MFCC matrix fixed to N_FRAMES ─────────────────\n        mfcc_seq = librosa.feature.mfcc(y=y, sr=sr, n_mfcc=N_MFCC)  # (40, T)\n        # Pad or truncate to exactly N_FRAMES columns\n        if mfcc_seq.shape[1] < N_FRAMES:\n            pad = N_FRAMES - mfcc_seq.shape[1]\n            mfcc_seq = np.pad(mfcc_seq, ((0,0),(0,pad)), mode='constant')\n        else:\n            mfcc_seq = mfcc_seq[:, :N_FRAMES]\n        mfcc_seq = mfcc_seq.T   # → (N_FRAMES, N_MFCC) = (128, 40)\n\n        # ── SCALARS: 7 cleaned feature values (delta-normalized) ─────────────\n        zcr  = librosa.feature.zero_crossing_rate(y=y).mean()\n        rms  = librosa.feature.rms(y=y).mean()\n        mel  = librosa.feature.melspectrogram(y=y, sr=sr).mean()\n        sc   = librosa.feature.spectral_centroid(y=y, sr=sr).mean()\n        sb   = librosa.feature.spectral_bandwidth(y=y, sr=sr).mean()\n        # Chroma mean + std as 2 scalar summaries\n        chroma = librosa.feature.chroma_stft(S=stft, sr=sr)\n        ch_mean = chroma.mean()\n        ch_std  = chroma.std()\n\n        all_sequences.append(mfcc_seq)\n        all_scalars.append([zcr, rms, mel, sc, sb, ch_mean, ch_std])\n        all_labels.append(row[\"emotion\"])\n\n    except Exception as e:\n        print(f\"  Skipped {row['file']}: {e}\")\n\nX_seq     = np.array(all_sequences, dtype=np.float32)  # (N, 128, 40)\nX_scalar  = np.array(all_scalars,   dtype=np.float32)  # (N, 7)\ny_labels  = np.array(all_labels)\n\nprint(f\"\\n✅ Sequence array shape : {X_seq.shape}\")\nprint(f\"   Scalar array shape   : {X_scalar.shape}\")\nprint(f\"   Labels shape         : {y_labels.shape}\")\nprint(f\"   Class counts         :\")\nunique, counts = np.unique(y_labels, return_counts=True)\nfor u, c in zip(unique, counts):\n    print(f\"     {u:10s}: {c}\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:08:33.951331Z","iopub.execute_input":"2026-02-28T20:08:33.951662Z","iopub.status.idle":"2026-02-28T20:10:49.499392Z","shell.execute_reply.started":"2026-02-28T20:08:33.951638Z","shell.execute_reply":"2026-02-28T20:10:49.498761Z"},"papermill":{"duration":179.765998,"end_time":"2026-02-27T23:57:07.978381","exception":false,"start_time":"2026-02-27T23:54:08.212383","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stdout","text":"Extracting SEQUENCE features from 3772 surviving files...\nOutput shape per file: (128, 40)  — rich temporal representation\n  Processing file 0/3772 ...\n  Processing file 500/3772 ...\n  Processing file 1000/3772 ...\n  Processing file 1500/3772 ...\n  Processing file 2000/3772 ...\n  Processing file 2500/3772 ...\n  Processing file 3000/3772 ...\n  Processing file 3500/3772 ...\n\n✅ Sequence array shape : (3772, 128, 40)\n   Scalar array shape   : (3772, 7)\n   Labels shape         : (3772,)\n   Class counts         :\n     Angry     : 537\n     Fear      : 1018\n     Happy     : 1027\n     Sad       : 1190\n","output_type":"stream"}],"execution_count":50},{"id":"1fd1e112","cell_type":"markdown","source":"# 6. Class Balancing — Minority Oversampling\n> **FIX #3**: Repeat minority samples to match majority class instead of cutting majority down. Keeps all real data.","metadata":{"papermill":{"duration":0.071981,"end_time":"2026-02-27T23:57:08.120726","exception":false,"start_time":"2026-02-27T23:57:08.048745","status":"completed"},"tags":[]}},{"id":"8e80fd61","cell_type":"code","source":"# ══════════════════════════════════════════════════════════════════════════════\n#  CLASS DISTRIBUTION — NO BALANCING (imbalanced data fed directly)\n#\n#  class_weight will be passed to model.fit() so the loss function\n#  automatically compensates for imbalance — no oversampling needed.\n# ══════════════════════════════════════════════════════════════════════════════\n\nunique_cls, counts_cls = np.unique(y_labels, return_counts=True)\n\nplt.figure(figsize=(8, 4))\nsns.barplot(x=unique_cls, y=counts_cls, palette='Set2')\nplt.title(\"Class Distribution (No Balancing Applied)\", fontweight='bold')\nfor i, (u, c) in enumerate(zip(unique_cls, counts_cls)):\n    plt.text(i, c + 5, str(c), ha='center', fontsize=10)\nplt.tight_layout(); plt.show()\n\nprint(\"Class counts:\", dict(zip(unique_cls, counts_cls)))\nprint(f\"\\nDataset — X_seq: {X_seq.shape}  |  X_sca: {X_scalar.shape}\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:10:49.500545Z","iopub.execute_input":"2026-02-28T20:10:49.500772Z","iopub.status.idle":"2026-02-28T20:10:49.660843Z","shell.execute_reply.started":"2026-02-28T20:10:49.500750Z","shell.execute_reply":"2026-02-28T20:10:49.660155Z"},"papermill":{"duration":0.582986,"end_time":"2026-02-27T23:57:08.772127","exception":false,"start_time":"2026-02-27T23:57:08.189141","status":"completed"},"tags":[],"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 800x400 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Class counts: {np.str_('Angry'): np.int64(537), np.str_('Fear'): np.int64(1018), np.str_('Happy'): np.int64(1027), np.str_('Sad'): np.int64(1190)}\n\nDataset — X_seq: (3772, 128, 40)  |  X_sca: (3772, 7)\n","output_type":"stream"}],"execution_count":51},{"id":"6a20d504","cell_type":"markdown","source":"# 7. Data Augmentation\n> **FIX #2**: `balanced_meta` now rebuilt via `groupby+sample` (not broken index matching). Augmentation produces sequences, not mean scalars. Added `time_mask` as 4th augmentation type.","metadata":{"papermill":{"duration":0.07298,"end_time":"2026-02-27T23:57:08.927728","exception":false,"start_time":"2026-02-27T23:57:08.854748","status":"completed"},"tags":[]}},{"id":"051d9369","cell_type":"code","source":"# ══════════════════════════════════════════════════════════════════════════════\n#  DATA AUGMENTATION — on RAW (unbalanced) file list\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef augment_audio(y, sr, aug_type):\n    if aug_type == 'time_stretch':\n        return librosa.effects.time_stretch(y, rate=np.random.uniform(0.85, 1.15))\n    elif aug_type == 'pitch_shift':\n        return librosa.effects.pitch_shift(y, sr=sr, n_steps=np.random.uniform(-3, 3))\n    elif aug_type == 'noise':\n        return y + np.random.normal(0, np.random.uniform(0.001, 0.015), len(y))\n    elif aug_type == 'time_mask':\n        y2 = y.copy()\n        mask_len = int(np.random.uniform(0.05, 0.15) * len(y))\n        start    = np.random.randint(0, len(y) - mask_len)\n        y2[start:start+mask_len] = 0\n        return y2\n    return y\n\ndef extract_sequence(y, sr):\n    mfcc = librosa.feature.mfcc(y=y, sr=sr, n_mfcc=N_MFCC)\n    if mfcc.shape[1] < N_FRAMES:\n        mfcc = np.pad(mfcc, ((0,0),(0, N_FRAMES - mfcc.shape[1])), mode='constant')\n    else:\n        mfcc = mfcc[:, :N_FRAMES]\n    return mfcc.T.astype(np.float32)\n\ndef extract_scalars(y, sr):\n    stft   = np.abs(librosa.stft(y))\n    chroma = librosa.feature.chroma_stft(S=stft, sr=sr)\n    return np.array([\n        librosa.feature.zero_crossing_rate(y=y).mean(),\n        librosa.feature.rms(y=y).mean(),\n        librosa.feature.melspectrogram(y=y, sr=sr).mean(),\n        librosa.feature.spectral_centroid(y=y, sr=sr).mean(),\n        librosa.feature.spectral_bandwidth(y=y, sr=sr).mean(),\n        chroma.mean(),\n        chroma.std(),\n    ], dtype=np.float32)\n\n# ── Augment directly from raw metadata_final ─────────────────────────────────\naug_types = ['noise', 'time_stretch', 'pitch_shift', 'time_mask']\naug_seqs, aug_scas, aug_labs = [], [], []\n\nprint(f\"Augmenting {len(metadata_final)} files x {len(aug_types)} types ...\")\nfor i, (_, row) in enumerate(metadata_final.iterrows()):\n    if i % 200 == 0:\n        print(f\"  {i}/{len(metadata_final)} ...\")\n    try:\n        y, sr = librosa.load(row['file'], sr=22050)\n        for aug_type in aug_types:\n            y_aug = augment_audio(y, sr, aug_type)\n            aug_seqs.append(extract_sequence(y_aug, sr))\n            aug_scas.append(extract_scalars(y_aug, sr))\n            aug_labs.append(row['emotion'])\n    except Exception as e:\n        print(f\"  Skipped {row['file']}: {e}\")\n\nX_seq_aug = np.array(aug_seqs, dtype=np.float32)\nX_sca_aug = np.array(aug_scas, dtype=np.float32)\ny_aug     = np.array(aug_labs)\n\n# ── Combine original + augmented ─────────────────────────────────────────────\nX_seq_final = np.concatenate([X_seq,    X_seq_aug], axis=0)\nX_sca_final = np.concatenate([X_scalar, X_sca_aug], axis=0)\ny_final     = np.concatenate([y_labels, y_aug],      axis=0)\n\nsidx = np.random.permutation(len(y_final))\nX_seq_final = X_seq_final[sidx]\nX_sca_final = X_sca_final[sidx]\ny_final     = y_final[sidx]\n\nprint(f\"\\n✅ Final data (no balancing, raw + augmented):\")\nprint(f\"   X_seq : {X_seq_final.shape}\")\nprint(f\"   X_sca : {X_sca_final.shape}\")\nu3, c3 = np.unique(y_final, return_counts=True)\nfor u, c in zip(u3, c3):\n    print(f\"   {u:10s}: {c}\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:10:49.661664Z","iopub.execute_input":"2026-02-28T20:10:49.661870Z","iopub.status.idle":"2026-02-28T20:22:10.956457Z","shell.execute_reply.started":"2026-02-28T20:10:49.661851Z","shell.execute_reply":"2026-02-28T20:22:10.955784Z"},"papermill":{"duration":527.409022,"end_time":"2026-02-28T00:05:56.409486","exception":false,"start_time":"2026-02-27T23:57:09.000464","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stdout","text":"Augmenting 3772 files x 4 types ...\n  0/3772 ...\n  200/3772 ...\n  400/3772 ...\n  600/3772 ...\n  800/3772 ...\n  1000/3772 ...\n  1200/3772 ...\n  1400/3772 ...\n  1600/3772 ...\n  1800/3772 ...\n  2000/3772 ...\n  2200/3772 ...\n  2400/3772 ...\n  2600/3772 ...\n  2800/3772 ...\n  3000/3772 ...\n  3200/3772 ...\n  3400/3772 ...\n  3600/3772 ...\n\n✅ Final data (no balancing, raw + augmented):\n   X_seq : (18860, 128, 40)\n   X_sca : (18860, 7)\n   Angry     : 2685\n   Fear      : 5090\n   Happy     : 5135\n   Sad       : 5950\n","output_type":"stream"}],"execution_count":52},{"id":"54542610","cell_type":"markdown","source":"# 8. Data Preparation","metadata":{"papermill":{"duration":0.073427,"end_time":"2026-02-28T00:05:56.556395","exception":false,"start_time":"2026-02-28T00:05:56.482968","status":"completed"},"tags":[]}},{"id":"1b122875","cell_type":"code","source":"# ══════════════════════════════════════════════════════════════════════════════\n#  DATA PREPARATION — 4 classes, imbalanced (class_weight used in training)\n# ══════════════════════════════════════════════════════════════════════════════\nfrom sklearn.utils.class_weight import compute_class_weight\n\nNUM_CLASSES = 4\n\nle    = LabelEncoder()\ny_enc = le.fit_transform(y_final)\ny_cat = to_categorical(y_enc, num_classes=NUM_CLASSES)\n\n# Compute class weights to handle imbalance during training\ncw_vals = compute_class_weight('balanced', classes=np.unique(y_enc), y=y_enc)\nclass_weight_dict = dict(enumerate(cw_vals))\nprint(\"Class weights:\", {le.classes_[k]: round(v, 4) for k, v in class_weight_dict.items()})\n\n# Normalise sequences per-coefficient\nseq_scaler = StandardScaler()\nn, t, f    = X_seq_final.shape\nX_seq_norm = seq_scaler.fit_transform(\n    X_seq_final.reshape(-1, f)\n).reshape(n, t, f).astype(np.float32)\n\nsca_scaler = StandardScaler()\nX_sca_norm = sca_scaler.fit_transform(X_sca_final).astype(np.float32)\n\nX_seq_tr, X_seq_te, X_sca_tr, X_sca_te, y_tr, y_te = train_test_split(\n    X_seq_norm, X_sca_norm, y_cat,\n    test_size=0.2, random_state=RANDOM_STATE, stratify=y_enc\n)\n\nprint(f\"Train seq : {X_seq_tr.shape}  |  Test seq : {X_seq_te.shape}\")\nprint(f\"Train sca : {X_sca_tr.shape}  |  Test sca : {X_sca_te.shape}\")\nprint(f\"Train y   : {y_tr.shape}      |  Test y   : {y_te.shape}\")\nprint(f\"Classes   : {list(le.classes_)}\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:22:21.259605Z","iopub.execute_input":"2026-02-28T20:22:21.260306Z","iopub.status.idle":"2026-02-28T20:22:22.973041Z","shell.execute_reply.started":"2026-02-28T20:22:21.260278Z","shell.execute_reply":"2026-02-28T20:22:22.972430Z"},"papermill":{"duration":1.46962,"end_time":"2026-02-28T00:05:58.099897","exception":false,"start_time":"2026-02-28T00:05:56.630277","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stdout","text":"Class weights: {np.str_('Angry'): np.float64(1.7561), np.str_('Fear'): np.float64(0.9263), np.str_('Happy'): np.float64(0.9182), np.str_('Sad'): np.float64(0.7924)}\nTrain seq : (15088, 128, 40)  |  Test seq : (3772, 128, 40)\nTrain sca : (15088, 7)  |  Test sca : (3772, 7)\nTrain y   : (15088, 4)      |  Test y   : (3772, 4)\nClasses   : [np.str_('Angry'), np.str_('Fear'), np.str_('Happy'), np.str_('Sad')]\n","output_type":"stream"}],"execution_count":53},{"id":"fe8bb8e0","cell_type":"markdown","source":"# 9. Model Definitions\n> **FIX #4**: All models use `(128, 40)` sequence inputs. `recurrent_dropout` removed from LSTM layers → enables cuDNN GPU kernel. Scalar branch merged before dense head. Model sizes right-sized to data volume.","metadata":{"papermill":{"duration":0.072699,"end_time":"2026-02-28T00:05:58.246009","exception":false,"start_time":"2026-02-28T00:05:58.173310","status":"completed"},"tags":[]}},{"id":"ff5ea480","cell_type":"code","source":"# ══════════════════════════════════════════════════════════════════════════════\n#  MODEL 1 — Advanced 1D CNN  (FIX: operates on 128×40 sequences)\n#\n#  Improvements over old version:\n#  • Input is (128, 40) — 128 time frames × 40 MFCC coefficients\n#  • Residual skip connection in block 3\n#  • Scalar branch merged before dense head\n#  • No recurrent_dropout (GPU-friendly)\n#  • Reduced dropout rates to reduce over-regularisation\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef build_cnn(seq_shape, sca_shape, num_classes=NUM_CLASSES):\n    # ── Sequence branch ───────────────────────────────────────────────────────\n    seq_in = Input(shape=seq_shape, name='seq_input')\n\n    x = Conv1D(64, 5, padding='same', activation='relu',\n               kernel_regularizer=l2(1e-4))(seq_in)\n    x = BatchNormalization()(x)\n    x = MaxPooling1D(2)(x)\n    x = Dropout(0.2)(x)\n\n    x = Conv1D(128, 5, padding='same', activation='relu',\n               kernel_regularizer=l2(1e-4))(x)\n    x = BatchNormalization()(x)\n    x = MaxPooling1D(2)(x)\n    x = Dropout(0.2)(x)\n\n    # Residual block\n    skip = Conv1D(256, 1, padding='same')(x)\n    x = Conv1D(256, 3, padding='same', activation='relu',\n               kernel_regularizer=l2(1e-4))(x)\n    x = BatchNormalization()(x)\n    x = Conv1D(256, 3, padding='same', kernel_regularizer=l2(1e-4))(x)\n    x = BatchNormalization()(x)\n    x = Add()([x, skip])\n    x = tf.keras.activations.relu(x)\n    x = Dropout(0.25)(x)\n\n    x = Conv1D(512, 3, padding='same', activation='relu',\n               kernel_regularizer=l2(1e-4))(x)\n    x = BatchNormalization()(x)\n    x = GlobalAveragePooling1D()(x)   # → (512,)\n    x = Dropout(0.3)(x)\n\n    # ── Scalar branch ─────────────────────────────────────────────────────────\n    sca_in = Input(shape=sca_shape, name='sca_input')\n    s = Dense(32, activation='relu')(sca_in)\n    s = BatchNormalization()(s)\n\n    # ── Merge & dense head ────────────────────────────────────────────────────\n    merged = tf.keras.layers.concatenate([x, s])\n    merged = Dense(256, activation='relu', kernel_regularizer=l2(1e-4))(merged)\n    merged = Dropout(0.3)(merged)\n    merged = Dense(128, activation='relu', kernel_regularizer=l2(1e-4))(merged)\n    merged = Dropout(0.2)(merged)\n    out    = Dense(num_classes, activation='softmax')(merged)\n\n    model = Model(inputs=[seq_in, sca_in], outputs=out, name='Advanced_CNN')\n    model.compile(\n        optimizer=tf.keras.optimizers.Adam(learning_rate=5e-4),\n        loss='categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    return model\n\ncnn_model = build_cnn(X_seq_tr.shape[1:], X_sca_tr.shape[1:])\ncnn_model.summary()\nprint(\"✅ Advanced CNN built.\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:22:22.974384Z","iopub.execute_input":"2026-02-28T20:22:22.974875Z","iopub.status.idle":"2026-02-28T20:22:25.013891Z","shell.execute_reply.started":"2026-02-28T20:22:22.974853Z","shell.execute_reply":"2026-02-28T20:22:25.013344Z"},"papermill":{"duration":2.488694,"end_time":"2026-02-28T00:06:00.807912","exception":false,"start_time":"2026-02-28T00:05:58.319218","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stderr","text":"I0000 00:00:1772310143.609600      55 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 15511 MB memory:  -> device: 0, name: Tesla P100-PCIE-16GB, pci bus id: 0000:00:04.0, compute capability: 6.0\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"Advanced_CNN\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"Advanced_CNN\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1m   Param #\u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[