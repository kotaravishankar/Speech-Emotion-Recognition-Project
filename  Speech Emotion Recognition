t = df[df[target_column] == emotion]\n        plt.scatter(subset.index, subset[feature], label=emotion, alpha=0.7)\n\n    plt.title(f\"Scatter Plot: {feature} by Sample Index\")\n    plt.xlabel(\"Sample Index\")\n    plt.ylabel(feature)\n    plt.legend(title=target_column)\n    plt.grid(True)\n    plt.show()\n\ndef plot_correlation_heatmap(df, target_column=\"emotion\", annot=True):\n    label_encoder = LabelEncoder()\n    df_copy = df.copy()\n    df_copy[target_column + \"_numeric\"] = label_encoder.fit_transform(df_copy[target_column])\n    df_copy.drop(target_column, axis=1, inplace=True)\n    correlation_matrix = df_copy.corr()\n    plt.figure(figsize=(12, 10))\n    sns.heatmap(correlation_matrix, annot=annot, cmap=\"coolwarm\", fmt=\".2f\", linewidths=0.5)\n    plt.title(\"Correlation Heatmap with Encoded Target\")\n    plt.show()\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T19:57:52.168315Z","iopub.execute_input":"2026-02-28T19:57:52.168636Z","iopub.status.idle":"2026-02-28T19:57:52.178094Z","shell.execute_reply.started":"2026-02-28T19:57:52.168609Z","shell.execute_reply":"2026-02-28T19:57:52.177471Z"},"id":"bcca7ebe","papermill":{"duration":0.04896,"end_time":"2026-02-27T23:48:42.639857","exception":false,"start_time":"2026-02-27T23:48:42.590897","status":"completed"},"tags":[],"trusted":true},"outputs":[],"execution_count":12},{"id":"1125fe99","cell_type":"markdown","source":"# 4. Feature Extraction with Cascading Outlier Removal\n> Each feature is extracted from the files that survived the **previous feature's outlier removal**. This ensures no \"ghost\" samples pollute downstream features.","metadata":{"id":"t5knFMlZuSK6","papermill":{"duration":0.036388,"end_time":"2026-02-27T23:48:42.713092","exception":false,"start_time":"2026-02-27T23:48:42.676704","status":"completed"},"tags":[]}},{"id":"0d70d723","cell_type":"code","source":"# ══════════════════════════════════════════════════════════════════════════════\n#  SHARED OUTLIER HELPERS  — used for all 7 features\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef detect_outliers_iqr(df, feature):\n    \"\"\"Return boolean mask: True = outlier (1.5×IQR rule).\"\"\"\n    Q1, Q3 = df[feature].quantile(0.25), df[feature].quantile(0.75)\n    IQR = Q3 - Q1\n    return (df[feature] < Q1 - 1.5*IQR) | (df[feature] > Q3 + 1.5*IQR)\n\ndef summarise_outliers(df, feature, label):\n    mask = detect_outliers_iqr(df, feature)\n    print(f\"\\n{'═'*55}\")\n    print(f\"  {label}  —  Outlier Summary (IQR Method)\")\n    print(f\"{'═'*55}\")\n    print(f\"  Total samples  : {len(df)}\")\n    print(f\"  Total outliers : {mask.sum()}  ({mask.mean()*100:.1f}%)\")\n    print(\"  Per-class breakdown:\")\n    for emo in sorted(df['emotion'].unique()):\n        sub = df[df['emotion'] == emo]\n        m   = detect_outliers_iqr(sub, feature)\n        print(f\"    {emo:10s}: {m.sum():4d} outliers / {len(sub)} samples\")\n    return mask\n\ndef plot_outlier_count_bar(df, feature, label):\n    mask   = detect_outliers_iqr(df, feature)\n    counts = df[mask].groupby('emotion').size().reset_index(name='Outlier Count')\n    plt.figure(figsize=(8, 4))\n    sns.barplot(data=counts, x='emotion', y='Outlier Count', palette='Reds_d')\n    plt.title(f'{label} — Outlier Count per Emotion Class', fontweight='bold')\n    plt.xlabel('Emotion'); plt.ylabel('Outlier Count')\n    plt.tight_layout(); plt.show()\n\ndef plot_before_after(df_before, df_after, feature, label):\n    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n    sns.boxplot(data=df_before, x='emotion', y=feature, ax=axes[0], palette='Set2')\n    axes[0].set_title(f'{label}\\nBEFORE Removal  (n={len(df_before)})',\n                      fontsize=11, fontweight='bold')\n    axes[0].tick_params(axis='x', rotation=30)\n\n    sns.boxplot(data=df_after, x='emotion', y=feature, ax=axes[1], palette='Set1')\n    axes[1].set_title(f'{label}\\nAFTER Removal  (n={len(df_after)})',\n                      fontsize=11, fontweight='bold')\n    axes[1].tick_params(axis='x', rotation=30)\n    plt.tight_layout(); plt.show()\n\ndef remove_outliers(df, feature):\n    mask = detect_outliers_iqr(df, feature)\n    cleaned = df[~mask].reset_index(drop=True)\n    return cleaned\n\nprint(\"Outlier helpers loaded.\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:03:38.111875Z","iopub.execute_input":"2026-02-28T20:03:38.112645Z","iopub.status.idle":"2026-02-28T20:03:38.123421Z","shell.execute_reply.started":"2026-02-28T20:03:38.112619Z","shell.execute_reply":"2026-02-28T20:03:38.122790Z"},"id":"mCL7sDIwuSK7","outputId":"27536c9f-13bf-40d9-82b7-c2ea3b38047b","papermill":{"duration":0.052201,"end_time":"2026-02-27T23:48:42.801424","exception":false,"start_time":"2026-02-27T23:48:42.749223","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stdout","text":"Outlier helpers loaded.\n","output_type":"stream"}],"execution_count":13},{"id":"bc2c5837","cell_type":"markdown","source":"## Feature 1 — Zero Crossing Rate","metadata":{"id":"w_YBI8LvuSK8","papermill":{"duration":0.036903,"end_time":"2026-02-27T23:48:42.874644","exception":false,"start_time":"2026-02-27T23:48:42.837741","status":"completed"},"tags":[]}},{"id":"f470d02a","cell_type":"code","source":"# ══════════════════════════════════════════════════════════════════════════════\n#  FEATURE 1 — Zero Crossing Rate\n#  Input: full metadata_df  →  Output: zcr_df (raw) + zcr_df_clean + surviving_files_after_zcr\n# ══════════════════════════════════════════════════════════════════════════════\n\nzcr_list = []\nfor _, row in metadata_df.iterrows():\n    data, sr = librosa.load(row[\"file\"])\n    zcr_list.append([librosa.feature.zero_crossing_rate(y=data).mean(), row[\"emotion\"], row[\"file\"]])\n\nzcr_df_raw = pd.DataFrame(zcr_list, columns=[\"ZCR\", \"emotion\", \"file\"])\nprint(f\"ZCR raw shape: {zcr_df_raw.shape}\")\nprint(zcr_df_raw[\"emotion\"].value_counts())\n","metadata":{"execution":{"iopub.st