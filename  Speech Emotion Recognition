)\n    x = Dropout(0.25)(x)\n\n    sca_in = Input(shape=sca_shape, name='sca_input')\n    s = Dense(32, activation='relu')(sca_in)\n    s = BatchNormalization()(s)\n\n    merged = tf.keras.layers.concatenate([x, s])\n    merged = Dense(256, activation='relu', kernel_regularizer=l2(1e-4))(merged)\n    merged = Dropout(0.3)(merged)\n    merged = Dense(128, activation='relu', kernel_regularizer=l2(1e-4))(merged)\n    merged = Dropout(0.2)(merged)\n    out    = Dense(num_classes, activation='softmax')(merged)\n\n    model = Model(inputs=[seq_in, sca_in], outputs=out, name='Advanced_BiLSTM')\n    model.compile(\n        optimizer=tf.keras.optimizers.Adam(learning_rate=5e-4),\n        loss='categorical_crossentropy',\n        metrics=['accuracy']\n    )\n    return model\n\nlstm_model = build_bilstm(X_seq_tr.shape[1:], X_sca_tr.shape[1:])\nlstm_model.summary()\nprint(\"✅ Advanced BiLSTM built.\")\n","metadata":{"execution":{"iopub.status.busy":"2026-02-28T20:22:25.014755Z","iopub.execute_input":"2026-02-28T20:22:25.014981Z","iopub.status.idle":"2026-02-28T20:22:25.312736Z","shell.execute_reply.started":"2026-02-28T20:22:25.014962Z","shell.execute_reply":"2026-02-28T20:22:25.312124Z"},"papermill":{"duration":1.007826,"end_time":"2026-02-28T00:06:01.887753","exception":false,"start_time":"2026-02-28T00:06:00.879927","status":"completed"},"tags":[],"trusted":true},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"Advanced_BiLSTM\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"Advanced_BiLSTM\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"┏━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━┓\n┃\u001b[1m \u001b[0m\u001b[1mLayer (type)       \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mOutput Shape     \u001b[0m\u001b